# Sway config — sowndev0106
# Docs: man 5 sway

### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

set $term foot
set $menu ~/.config/sway/scripts/rofi-focused.sh -show drun

# Giữ Super + kéo chuột để DI CHUYỂN cửa sổ nổi (Super + chuột phải để đổi kích thước)
floating_modifier $mod normal
# Launcher dự phòng (wofi): bind Super+Shift+d
set $menu_alt wofi --show drun

### Output (màn hình) - chạy `swaymsg -t get_outputs` để xem tên output
# Nền màu trơn (mặc định). Muốn dùng ảnh thật: comment dòng dưới và bỏ comment dòng kế.
# output * bg #1e1e2e solid_color
# Kiểu hiển thị ảnh: fill | fit | stretch | center | tile
output * bg ~/Downloads/pexels-flickr-149246.jpg fill

# Bố cục màn hình do kanshi quản lý (xem ~/.config/kanshi/config) — KHÔNG đặt
# `output ... position` ở đây nữa, sẽ đá nhau với kanshi. Chỉnh tay bằng wdisplays
# rồi chép vị trí vào file kanshi để giữ vĩnh viễn.

### Idle / lock màn hình
exec swayidle -w \
    timeout 300 '~/.config/sway/scripts/lock.sh' \
    timeout 600 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f'

### Input — gõ `swaymsg -t get_inputs` để xem device
input "type:touchpad" {
    tap enabled
    natural_scroll enabled
    dwt enabled
}
input "type:keyboard" {
    xkb_layout us
    repeat_delay 300
    repeat_rate 40
    xkb_numlock enabled
}

### Con trỏ chuột (theme + kích thước, hợp HiDPI)
seat * xcursor_theme Yaru 24

### Cử chỉ touchpad — vuốt 3 ngón đổi workspace
bindgesture swipe:3:right workspace prev
bindgesture swipe:3:left workspace next

### Key bindings — cơ bản
bindsym $mod+Return exec $term
bindsym $mod+Shift+Return exec $term --app-id=foot-float   # terminal nổi nhanh
bindsym $mod+q kill
bindsym $mod+d exec pgrep -x rofi >/dev/null && pkill -x rofi || $menu
bindsym $mod+Shift+d exec $menu_alt
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec wlogout -b 5 -m 8

# Di chuyển focus
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Di chuyển cửa sổ
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

### Workspaces
# Phím số thường
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Phím số Numpad (phải bật NumLock)
bindsym $mod+KP_1 workspace number 1
bindsym $mod+KP_2 workspace number 2
bindsym $mod+KP_3 workspace number 3
bindsym $mod+KP_4 workspace number 4
bindsym $mod+KP_5 workspace number 5
bindsym $mod+KP_6 workspace number 6
bindsym $mod+KP_7 workspace number 7
bindsym $mod+KP_8 workspace number 8
bindsym $mod+KP_9 workspace number 9
bindsym $mod+KP_0 workspace number 10

# Di chuyển container bằng phím số thường
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Di chuyển container bằng phím Numpad (phải bật NumLock)
bindsym $mod+Shift+KP_1 move container to workspace number 1
bindsym $mod+Shift+KP_2 move container to workspace number 2
bindsym $mod+Shift+KP_3 move container to workspace number 3
bindsym $mod+Shift+KP_4 move container to workspace number 4
bindsym $mod+Shift+KP_5 move container to workspace number 5
bindsym $mod+Shift+KP_6 move container to workspace number 6
bindsym $mod+Shift+KP_7 move container to workspace number 7
bindsym $mod+Shift+KP_8 move container to workspace number 8
bindsym $mod+Shift+KP_9 move container to workspace number 9
bindsym $mod+Shift+KP_0 move container to workspace number 10
bindsym $mod+Ctrl+Shift+Right move workspace to output right
bindsym $mod+Ctrl+Shift+Left move workspace to output left

### Layout
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e exec nautilus
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
# Bật/tắt màn hình laptop (dùng khi muốn chỉ xài 2 màn ngoài HDMI+DP)
bindsym $mod+o output eDP-1 toggle
# Chỉnh màn hình bằng wdisplays (tắt kanshi để khỏi tranh chấp) rồi TỰ LƯU khi đóng
bindsym $mod+Shift+o exec ~/.config/sway/scripts/edit-display-layout.sh
# Xem danh sách phím tắt và tìm kiếm/chạy nhanh
bindsym $mod+slash exec ~/.config/sway/scripts/show-shortcuts.py

### Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Alt+Tab Switcher — không cần mode riêng, tất cả ở global scope
# Lý do: bindsym --release Alt_L chỉ fire được trong default mode.
# toggle_next/toggle_prev tự xử lý: nếu switcher chưa mở → start; nếu đã mở → navigate
bindsym Mod1+Tab         exec python3 ~/.config/eww/scripts/alt_tab.py toggle_next
bindsym Mod1+Shift+Tab   exec python3 ~/.config/eww/scripts/alt_tab.py toggle_prev

# Nhả Alt → tự động focus cửa sổ đang chọn (không cần Enter)
bindsym --release Alt_L  exec python3 ~/.config/eww/scripts/alt_tab.py check_and_select
bindsym --release Alt_R  exec python3 ~/.config/eww/scripts/alt_tab.py check_and_select

# Hủy bằng Alt+Escape (nếu muốn cancel mà không chọn)
bindsym Mod1+Escape      exec python3 ~/.config/eww/scripts/alt_tab.py close

### Resize mode
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

### Resize trực tiếp (không cần vào mode)
bindsym $mod+Ctrl+Left  resize shrink width 30px
bindsym $mod+Ctrl+Right resize grow   width 30px
bindsym $mod+Ctrl+Up    resize shrink height 30px
bindsym $mod+Ctrl+Down  resize grow   height 30px

### Phím media / độ sáng (kèm OSD qua wob)
bindsym XF86AudioRaiseVolume exec ~/.config/sway/scripts/vol.sh 5%+
bindsym XF86AudioLowerVolume exec ~/.config/sway/scripts/vol.sh 5%-
bindsym XF86AudioMute exec ~/.config/sway/scripts/vol.sh toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86MonBrightnessUp exec ~/.config/sway/scripts/bri.sh 5%+
bindsym XF86MonBrightnessDown exec ~/.config/sway/scripts/bri.sh 5%-
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

### Screenshot (grimshot — tự lưu/copy + thông báo)
bindsym Print exec grimshot save screen          # toàn màn hình -> file
bindsym Shift+Print exec grimshot copy area       # chọn vùng -> clipboard
bindsym $mod+Print exec grimshot save area        # chọn vùng -> file
bindsym $mod+Shift+s exec grimshot copy area       # snip -> clipboard
# Quay màn hình: bấm lần 1 chọn vùng & quay, lần 2 dừng
bindsym $mod+Shift+r exec ~/.config/sway/scripts/record.sh

### Lịch sử clipboard (cliphist) — chọn lại nội dung đã copy
bindsym $mod+Shift+v exec cliphist list | ~/.config/sway/scripts/rofi-focused.sh -dmenu -p "Clipboard" | cliphist decode | wl-copy

### Khóa màn hình thủ công (nền blur desktop)
bindsym $mod+Shift+x exec ~/.config/sway/scripts/lock.sh

### Gaps & viền
gaps inner 0
gaps outer 0
# Khi reload, workspace đang mở có thể vẫn giữ gap cũ. Ép tất cả về đúng kiểu đang dùng.
exec_always swaymsg 'gaps inner all set 0; gaps outer all set 0'
default_border pixel 3
default_floating_border pixel 2
smart_gaps on
smart_borders on
hide_edge_borders both

# Màu viền (theme Catppuccin Mocha-ish)
# Màu thứ 4 (indicator) = #f38ba8 (đỏ) để thấy được hướng split: cạnh đỏ là nơi window mới sẽ mở
client.focused          #89b4fa #89b4fa #1e1e2e #f38ba8 #89b4fa
client.unfocused        #313244 #313244 #cdd6f4 #313244 #313244
client.focused_inactive #45475a #45475a #cdd6f4 #45475a #45475a

### Quy tắc cửa sổ nổi (floating) — hộp thoại & app cấu hình tự nổi giữa màn hình
for_window [app_id="pavucontrol"] floating enable
for_window [app_id="cc-switch"] floating enable, resize set 900 600, move position center
for_window [app_id="blueman-manager"] floating enable
for_window [app_id="nm-connection-editor"] floating enable
for_window [app_id="fcitx5-config-qt"] floating enable
for_window [app_id="org.fcitx.fcitx5-config-qt"] floating enable
for_window [app_id="org.gnome.Calendar"] floating enable, resize set 1100 760, move position center
for_window [app_id="org.gnome.Nautilus"] floating enable, resize set 70 ppt 70 ppt, move position center
for_window [app_id="thunar" title="(?i)(properties|preferences|rename|file operation)"] floating enable
# Terminal nổi nhanh (Super+Shift+Return): nổi, 900x550, giữa màn hình
for_window [app_id="foot-float"] floating enable, resize set 900 550, move position center
for_window [window_role="pop-up"] floating enable
for_window [window_role="bubble"] floating enable
for_window [window_role="dialog"] floating enable
for_window [window_type="dialog"] floating enable

### Bar
bar {
    swaybar_command waybar
}

### Autostart
exec mako
exec_always /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1
# Bộ gõ tiếng Việt (Unikey qua fcitx5)
exec fcitx5 -d --replace
# Lưu lịch sử clipboard (xem lại bằng Mod+Shift+v)
exec wl-paste --watch cliphist store
# Dock app dưới màn hình: tạm tắt autostart. Bật lại bằng cách bỏ comment
# dòng dưới rồi `swaymsg reload`, hoặc chạy thủ công:
#   ~/.config/sway/scripts/dock.sh
# exec_always ~/.config/sway/scripts/dock.sh
# WiFi/mạng và Bluetooth giờ hiển thị bằng module waybar (icon sáng màu),
# nên KHÔNG chạy applet tray nữa (icon tray xám tối, khó nhìn).
# Backend vẫn hoạt động: NetworkManager + bluetooth.service chạy nền độc lập.
# Quản lý mạng: click icon mạng trên bar (mở nm-connection-editor) hoặc `nmtui`.
# Ghép thiết bị BT: click icon bluetooth (mở blueman-manager) hoặc `bluetoothctl`.
# exec nm-applet --indicator
# exec blueman-applet
# OSD volume/độ sáng (wob) — tạo fifo rồi đọc vào wob
exec rm -f $XDG_RUNTIME_DIR/wob.sock && mkfifo $XDG_RUNTIME_DIR/wob.sock && tail -f $XDG_RUNTIME_DIR/wob.sock | wob
# Tự sắp xếp màn hình khi cắm/rút màn ngoài.
# exec_always + kill cũ: mỗi lần reload (Super+Shift+C) kanshi chạy lại và áp dụng
# lại bố cục, nếu không layout sẽ bị reset về mặc định khi reload.
exec_always pkill -x kanshi; kanshi

include /etc/sway/config.d/*
